{
  "name": "sis-backend",
  "version": "1.0.0",
  "description": "SIS Backend API - Node.js Express Server",
  "main": "src/app.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "cross-env NODE_ENV=test node scripts/buildCheck.js",
    "test": "jest --testTimeout=10000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --testTimeout=30000",
    "test:e2e": "jest --testPathPattern=tests/e2e --testTimeout=60000",
    "seed": "node src/seeders/index.js",
    "seed:dev": "cross-env NODE_ENV=development node src/seeders/index.js",
    "seed:prod": "cross-env NODE_ENV=production node src/seeders/index.js",
    "migrate": "node src/migrations/index.js",
    "worker:notifications": "cross-env NODE_ENV=production node src/workers/notificationWorker.js",
    "worker:files": "cross-env NODE_ENV=production node src/workers/fileWorker.js",
    "worker:dev": "nodemon src/workers/index.js",
    "postinstall": "echo 'Installation completed successfully'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "health": "node -e \"const http=require('http'); const port=process.env.PORT||5000; http.get(`http://localhost:${port}/api/v1/health`, (res) => process.exit(res.statusCode===200?0:1)).on('error', () => process.exit(1));\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.3",
    "puppeteer": "^21.6.1",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "lodash": "^4.17.21",
    "validator": "^13.11.0",
    "compression": "^1.7.4",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "express-async-errors": "^3.1.1",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "bull": "^4.12.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "i18next": "^23.7.6",
    "i18next-fs-backend": "^2.3.1",
    "csv-parse": "^5.5.2",
    "csv-stringify": "^6.4.4",
    "xlsx": "^0.18.5",
    "archiver": "^6.0.1",
    "express-fileupload": "^1.4.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "mongodb-memory-server": "^9.1.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "@types/jest": "^29.5.8"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/seeders/**",
      "!src/migrations/**"
    ]
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "rest-api",
    "university",
    "student-management"
  ],
  "author": "SIS Development Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
