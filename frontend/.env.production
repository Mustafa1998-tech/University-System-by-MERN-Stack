# Production environment variables
REACT_APP_API_URL=https://your-production-api.com/api
REACT_APP_APP_NAME=University SIS
REACT_APP_VERSION=1.0.0

# API Configuration
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_RETRY_ATTEMPTS=3

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png,.txt

# Feature Flags
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_RTL=true

# Third-party Services
REACT_APP_GOOGLE_ANALYTICS_ID=YOUR_GA_ID
REACT_APP_SENTRY_DSN=YOUR_SENTRY_DSN

# Production Settings
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=error

# Localization
REACT_APP_DEFAULT_LANGUAGE=ar
REACT_APP_SUPPORTED_LANGUAGES=ar,en

# Cache Configuration
REACT_APP_CACHE_DURATION=300000

# WebSocket Configuration (if needed)
REACT_APP_WS_URL=wss://your-production-api.com